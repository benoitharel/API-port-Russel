<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Ajouter un utilisateur' }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="user-new">
    <h1>Ajouter un utilisateur</h1>

    <% if (errors.length > 0) { %>
      <ul class="error">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/dashboard/users" method="POST">
      <label for="username">Nom</label>
      <input type="text" id="username" name="username" value="<%= values.username || '' %>" required>

      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= values.email || '' %>" required>

      <label for="password">Mot de passe</label>
      <input type="password" id="password" name="password" required>

      <button type="submit">Créer</button>
    </form>

    <p><a href="/dashboard/users">Retour à la liste</a></p>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
