<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Modifier ' + user.username }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="user-edit">
    <h1>Modifier <%= user.username %></h1>

    <% if (errors.length > 0) { %>
      <ul class="error">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/dashboard/users/<%= encodeURIComponent(originalEmail) %>" method="POST">
      <label for="username">Nom</label>
      <input type="text" id="username" name="username" value="<%= user.username %>" required>

      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= user.email %>" required>

      <label for="password">Nouveau mot de passe (laisser vide pour ne pas changer)</label>
      <input type="password" id="password" name="password">

      <button type="submit">Enregistrer</button>
    </form>

    <p class="page-links"><a href="/dashboard/users/<%= encodeURIComponent(originalEmail) %>">Annuler</a></p>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
