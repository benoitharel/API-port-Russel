<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Modifier réservation' }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="reservation-edit">
    <h1>Modifier la réservation de <%= reservation.clientName %></h1>

    <% if (errors.length > 0) { %>
      <ul class="error">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/dashboard/reservations/<%= reservation._id %>" method="POST">
      <input type="hidden" name="from" value="<%= from %>">

      <label for="catwayNumber">Catway</label>
      <select id="catwayNumber" name="catwayNumber" required>
        <% catways.forEach(c => { %>
          <option value="<%= c.catwayNumber %>" <%= reservation.catwayNumber === c.catwayNumber ? 'selected' : '' %>>
            <%= c.catwayNumber %> (<%= c.catwayType %>)
          </option>
        <% }) %>
      </select>

      <label for="clientName">Client</label>
      <input type="text" id="clientName" name="clientName" value="<%= reservation.clientName %>" required>

      <label for="boatName">Bateau</label>
      <input type="text" id="boatName" name="boatName" value="<%= reservation.boatName %>" required>

      <label for="startDate">Début</label>
      <input type="date" id="startDate" name="startDate" value="<%= reservation.startDate.toISOString().slice(0, 10) %>" required>

      <label for="endDate">Fin</label>
      <input type="date" id="endDate" name="endDate" value="<%= reservation.endDate.toISOString().slice(0, 10) %>" required>

      <button type="submit">Enregistrer</button>
    </form>

    <p class="page-links"><a href="<%= cancelUrl %>">Annuler</a></p>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
