<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Modifier catway ' + catway.catwayNumber }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="catway-edit">
    <h1>Modifier catway <%= catway.catwayNumber %></h1>

    <% if (errors.length > 0) { %>
      <ul class="error">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/dashboard/catways/<%= catway.catwayNumber %>" method="POST">
      <p>Numéro : <%= catway.catwayNumber %></p>
      <p>Type : <%= catway.catwayType %></p>

      <label for="catwayState">État</label>
      <input type="text" id="catwayState" name="catwayState" value="<%= catway.catwayState %>" required>

      <button type="submit">Enregistrer</button>
    </form>

    <p class="page-links"><a href="/dashboard/catways/<%= catway.catwayNumber %>">Annuler</a></p>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
