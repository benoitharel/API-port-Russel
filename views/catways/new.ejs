<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Ajouter un catway' }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="catway-new">
    <h1>Ajouter un catway</h1>

    <% if (errors.length > 0) { %>
      <ul class="error">
        <% errors.forEach(e => { %>
          <li><%= e %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/dashboard/catways" method="POST">
      <label for="catwayNumber">Numéro</label>
      <input type="number" id="catwayNumber" name="catwayNumber" value="<%= values.catwayNumber || '' %>" required>

      <label for="catwayType">Type</label>
      <select id="catwayType" name="catwayType" required>
        <option value="long" <%= values.catwayType === 'long' ? 'selected' : '' %>>Long</option>
        <option value="short" <%= values.catwayType === 'short' ? 'selected' : '' %>>Short</option>
      </select>

      <label for="catwayState">État</label>
      <input type="text" id="catwayState" name="catwayState" value="<%= values.catwayState || '' %>" required>

      <button type="submit">Créer</button>
    </form>

    <p><a href="/dashboard/catways">Retour à la liste</a></p>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
