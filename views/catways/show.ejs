<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Catway ' + catway.catwayNumber }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="catway-show">
    <h1>Catway <%= catway.catwayNumber %></h1>

    <p>Type : <%= catway.catwayType %></p>
    <p>État : <%= catway.catwayState %></p>

    <div class="resource-actions">
      <a href="/dashboard/catways/<%= catway.catwayNumber %>/edit" class="btn btn-secondary">Modifier</a>

      <form action="/dashboard/catways/<%= catway.catwayNumber %>/delete" method="POST"
            onsubmit="return confirm('Supprimer ce catway ?');" class="inline-form">
        <button type="submit" class="btn btn-danger">Supprimer</button>
      </form>
    </div>

    <p class="page-links">
      <a href="/dashboard/catways">&larr; Retour à la liste</a>
      &middot;
      <a href="/dashboard/catways/new">Ajouter un catway</a>
    </p>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
