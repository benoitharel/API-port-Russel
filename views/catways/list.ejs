<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head', { title: 'Catways' }) %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main class="catways-list">
    <h1>Catways</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <p><a href="/dashboard/catways/new">Ajouter un catway</a></p>

    <table>
      <thead>
        <tr>
          <th>Numéro</th>
          <th>Type</th>
          <th>État</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% catways.forEach(c => { %>
          <tr>
            <td><a href="/dashboard/catways/<%= c.catwayNumber %>"><%= c.catwayNumber %></a></td>
            <td><%= c.catwayType %></td>
            <td><%= c.catwayState %></td>
            <td class="actions-cell">
              <a href="/dashboard/catways/<%= c.catwayNumber %>/edit?from=list" class="btn btn-secondary btn-sm">Modifier</a>
              <form action="/dashboard/catways/<%= c.catwayNumber %>/delete" method="POST"
                    onsubmit="return confirm('Supprimer le catway <%= c.catwayNumber %> ?');" class="inline-form">
                <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
